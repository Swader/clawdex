# Copy this file to .env and fill in the Telegram token.
# The service reads .env directly with systemd EnvironmentFile.

FACTORY_TELEGRAM_BOT_TOKEN=
# Optional. Set this to the control supergroup chat id to register chat_member command scope on startup.
# FACTORY_TELEGRAM_CONTROL_CHAT_ID=-1001234567890
FACTORY_ALLOWED_TELEGRAM_USER_ID=16708526
FACTORY_DASHBOARD_HOST=127.0.0.1
FACTORY_DASHBOARD_PORT=8787
FACTORY_TELEGRAM_POLL_TIMEOUT_SECONDS=30
FACTORY_LOCAL_MACHINE=valkyrie
FACTORY_CONTROL_ROOT=/srv/telemux
FACTORY_FACTORY_ROOT=/srv/factory
# Optional override. Default worker config path is ./workers.json
# FACTORY_WORKERS_FILE=./workers.json
FACTORY_USAGE_ADAPTER=manual
FACTORY_CODEX_BIN=codex
